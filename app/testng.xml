<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Test Suite" verbose="1" parallel="methods" thread-count="3">

    <parameter name="browser" value="chrome"/>
    <parameter name="env"     value="qa"/>
    <parameter name="headless" value="true"/>

    <listeners>
        <listener class-name="com.qaproject.listeners.ExtentReportListener"/>
        <listener class-name="com.qaproject.listeners.RetryListener"/>
    </listeners>

    <test name="Unit Tests">
        <classes>
            <class name="com.qaproject.AppTest"/>
        </classes>
    </test>

</suite>
